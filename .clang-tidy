# Pure Google C++ lint. Run over host translation units (.cpp + the .hpp they
# pull in); .cu/.cuh device code is covered by clang-format only (clang-tidy
# would need a clang CUDA toolchain to parse nvcc command lines — see scripts/lint.sh).
Checks: >
  bugprone-*,
  performance-*,
  clang-analyzer-*,
  google-*,
  modernize-use-override,
  modernize-use-nullptr,
  modernize-use-using,
  readability-identifier-naming,
  -bugprone-easily-swappable-parameters,
  -google-runtime-references,
  -google-readability-todo,
  -google-readability-braces-around-statements,
  -clang-analyzer-security.insecureAPI.*

WarningsAsErrors: ''
HeaderFilterRegex: 'engine/src/.*\.(hpp|cuh)$'
FormatStyle: file

# Google identifier conventions. Deliberate exemptions for this engine's idioms:
#  - no Variable/Parameter case rule: keeps the BLAS-convention dimension names
#    (M, N, K, H, IN, OUT, ...) used throughout the GEMM/kernel code.
#  - no TypeAlias/Typedef case rule: keeps the primitive-like alias `bf16`.
# Functions/types/members/constants are still enforced (PascalCase / kConstants).
CheckOptions:
  - { key: readability-identifier-naming.NamespaceCase,          value: lower_case }
  - { key: readability-identifier-naming.ClassCase,              value: CamelCase  }
  - { key: readability-identifier-naming.StructCase,             value: CamelCase  }
  - { key: readability-identifier-naming.EnumCase,               value: CamelCase  }
  - { key: readability-identifier-naming.FunctionCase,           value: CamelCase  }
  - { key: readability-identifier-naming.MemberCase,             value: lower_case }
  - { key: readability-identifier-naming.PrivateMemberSuffix,    value: _          }
  - { key: readability-identifier-naming.ProtectedMemberSuffix,  value: _          }
  - { key: readability-identifier-naming.EnumConstantCase,       value: CamelCase  }
  - { key: readability-identifier-naming.EnumConstantPrefix,     value: k          }
  - { key: readability-identifier-naming.ConstexprVariableCase,  value: CamelCase  }
  - { key: readability-identifier-naming.ConstexprVariablePrefix, value: k         }
  - { key: readability-identifier-naming.GlobalConstantCase,     value: CamelCase  }
  - { key: readability-identifier-naming.GlobalConstantPrefix,   value: k          }
  - { key: readability-identifier-naming.MacroDefinitionCase,    value: UPPER_CASE }
